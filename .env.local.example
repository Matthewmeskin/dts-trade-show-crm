# Copy this file to `.env.local` and fill in values from your Supabase project
# (Supabase dashboard → Project Settings → API). Never commit `.env.local`.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe for the browser; access is gated by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses RLS. Used later by the n8n/TMS
# integration endpoint and admin tasks. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — powers the dashboard AI summary (claude-opus-4-8).
ANTHROPIC_API_KEY=

# Shared secret for the TMS ingest endpoint (n8n → POST /api/tms/shipments,
# header: Authorization: Bearer <this>). See TMS-INTEGRATION.md.
TMS_WEBHOOK_SECRET=
